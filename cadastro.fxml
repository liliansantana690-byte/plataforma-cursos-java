<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" alignment="CENTER" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.plataforma.controller.CadastroController"
      style="-fx-padding: 40; -fx-background-color: #f4f4f4;">

    <Label text="Criar Conta" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <TextField fx:id="campoNome" promptText="Nome completo" maxWidth="280"/>
    <TextField fx:id="campoEmail" promptText="Email" maxWidth="280"/>
    <PasswordField fx:id="campoSenha" promptText="Senha (mín. 6 caracteres)" maxWidth="280"/>
    <Button text="Cadastrar" onAction="#cadastrar" maxWidth="280"
            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 14px;"/>
    <Hyperlink text="Já tenho conta" onAction="#voltarLogin"/>
    <Label fx:id="lblErro" style="-fx-text-fill: red;"/>
    <Label fx:id="lblSucesso" style="-fx-text-fill: green;"/>

</VBox>
